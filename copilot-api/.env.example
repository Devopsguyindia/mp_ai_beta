COPILOT_ENV=dev

# MySQL (read-only user strongly recommended)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=masterpiece
MYSQL_USERNAME=readonly_user
MYSQL_PASSWORD=change_me

# Query limits
MYSQL_QUERY_TIMEOUT_MS=8000
MYSQL_MAX_ROWS=200

# LLM (optional for now; can run in stub mode without calling an LLM)
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL_SQL=gpt-4.1
OPENAI_MODEL_ROUTER=gpt-4.1-mini
AI_FIRST_SQL_ENABLED=1

# CORS — optional. Localhost + one CloudFront origin are merged in app/main.py. Default regex allows
# https://*.mpstest.net, https://*.cloudfront.net, and localhost. Override the regex only if needed:
# CORS_ALLOW_ORIGIN_REGEX=(^https?://(localhost|127\.0\.0\.1)(:\d+)?$)|(^https://.*\.yourdomain\.com$)
# Exact origins (in addition to regex matches):
# CORS_ALLOW_ORIGINS=https://doy5f9mehzv49.cloudfront.net,https://your-spa.example.com
#
# If the API is behind Nginx/ALB and CORS still fails: ensure OPTIONS is proxied to Uvicorn (or Nginx
# adds Access-Control-Allow-Origin for the SPA origin). A 200 from Nginx without CORS headers still
# blocks the browser.

# V3 agentic pipeline
V3_ASK_ENABLED=1
# Validate generated SQL column names against schema_registry (1=on)
V3_SCHEMA_COLUMN_CHECK=1
# Retry LLM SQL repair after MySQL unknown column (1054), up to N extra attempts
V3_MAX_DB_RETRIES=1
V3_VALIDATOR_MAX_RETRIES=1
V3_CHART_AGENT_ENABLED=0
V3_INSIGHT_LLM_ENABLED=1
V3_MIN_CONFIDENCE=0.55
V3_BLOCK_LOW_CONFIDENCE=0
V3_MEMORY_PGVECTOR_ENABLED=0
V3_MEMORY_USE_MYSQL=1
V3_MEMORY_TABLE_NAME=ai_v3_memory_events
V3_MEMORY_LOG_PATH=

