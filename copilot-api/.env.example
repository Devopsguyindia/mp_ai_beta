COPILOT_ENV=dev

# MySQL (read-only user strongly recommended)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=masterpiece
MYSQL_USERNAME=readonly_user
MYSQL_PASSWORD=change_me

# Query limits
MYSQL_QUERY_TIMEOUT_MS=8000
MYSQL_MAX_ROWS=200

# LLM (optional for now; can run in stub mode without calling an LLM)
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL_SQL=gpt-4.1
OPENAI_MODEL_ROUTER=gpt-4.1-mini
AI_FIRST_SQL_ENABLED=1

# CORS — optional. Default in app/main.py is local dev origins only (localhost / 127.0.0.1 on 4200, 4300, etc.).
# For deployed SPAs, set a comma-separated list:
# CORS_ALLOW_ORIGINS=https://your-spa.example.com,https://another-origin.example.com

# Report suggestions (POST /reports/suggestions). Set to 0 to disable (returns 404 report_suggestions_disabled).
REPORT_SUGGESTIONS_ENABLED=1

# Report re-run (POST /reports/rerun): rolling end dates to today. Set to 0 to keep stored *ToDate values as-is.
REPORT_RERUN_ROLL_END_DATES=1

# V3 agentic pipeline
V3_ASK_ENABLED=1
# Validate generated SQL column names against schema_registry (1=on)
V3_SCHEMA_COLUMN_CHECK=1
# Retry LLM SQL repair after MySQL unknown column (1054), up to N extra attempts
V3_MAX_DB_RETRIES=1
V3_VALIDATOR_MAX_RETRIES=1
V3_CHART_AGENT_ENABLED=0
V3_INSIGHT_LLM_ENABLED=1
V3_MIN_CONFIDENCE=0.55
V3_BLOCK_LOW_CONFIDENCE=0
V3_MEMORY_PGVECTOR_ENABLED=0
V3_MEMORY_USE_MYSQL=1
V3_MEMORY_TABLE_NAME=ai_v3_memory_events
V3_MEMORY_LOG_PATH=

# ERP module AI Insights: scope classifier (requires OPENAI_API_KEY when LLM enabled)
V3_MODULE_SCOPE_LLM_ENABLED=1
V3_MODULE_SCOPE_MODEL=gpt-4.1-mini

# Auth audit (POST /auth/login, /auth/logout). Requires INSERT on ai_v3_copilot_auth_audit (or override table name).
COPILOT_AUTH_AUDIT_ENABLED=1
COPILOT_AUTH_AUDIT_USE_MYSQL=1
COPILOT_AUTH_AUDIT_TABLE=ai_v3_copilot_auth_audit

