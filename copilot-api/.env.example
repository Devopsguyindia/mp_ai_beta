COPILOT_ENV=dev

# MySQL (read-only user strongly recommended)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=masterpiece
MYSQL_USERNAME=readonly_user
MYSQL_PASSWORD=change_me

# Query limits
MYSQL_QUERY_TIMEOUT_MS=8000
MYSQL_MAX_ROWS=200

# LLM (optional for now; can run in stub mode without calling an LLM)
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL_SQL=gpt-4.1
OPENAI_MODEL_ROUTER=gpt-4.1-mini
AI_FIRST_SQL_ENABLED=1

# CORS — optional. Default in app/main.py is local dev origins only (localhost / 127.0.0.1 on 4200, 4300, etc.).
# For deployed SPAs, set a comma-separated list:
# CORS_ALLOW_ORIGINS=https://your-spa.example.com,https://another-origin.example.com

# Report suggestions (POST /reports/suggestions). Set to 0 to disable (returns 404 report_suggestions_disabled).
REPORT_SUGGESTIONS_ENABLED=1

# Report re-run (POST /reports/rerun): rolling end dates to today. Set to 0 to keep stored *ToDate values as-is.
REPORT_RERUN_ROLL_END_DATES=1

# Artwork showcase (GET/POST /showcase/*). Off by default; does not load V3 or insights code paths.
SHOWCASE_ENABLED=1
# Optional: public API origin for absolute /showcase/render/.../preview URLs (batch + single). Use when the SPA calls a different host than the server sees (e.g. http://localhost:8001 vs http://127.0.0.1:8001).
# SHOWCASE_PUBLIC_API_BASE=http://localhost:8001
# Public asset CDN base for company_item_pictures URLs (server_path + picture appended).
MP_ASSET_CDN_BASE=https://masterpiece.s3.amazonaws.com
# Log JSON debug lines for /showcase picture fetches (sql_row_count, skips, hints). Also attach debug to responses when ?debug=1.
SHOWCASE_DEBUG_LOG=1
# Optional comma-separated hostname allowlist for resolved picture URLs (empty = allow any http(s) host).
SHOWCASE_ASSET_HOST_ALLOWLIST=masterpiece.s3.amazonaws.com
# Stream artwork through the API (GET .../pictures/{id}/file) so the browser avoids CDN hotlink/referrer issues. Set 0 to disable.
SHOWCASE_IMAGE_PROXY=1
SHOWCASE_IMAGE_PROXY_MAX_MB=25
SHOWCASE_IMAGE_FETCH_TIMEOUT_S=30
# Server-side PNG compositor (Pillow): POST /showcase/render caches bytes; GET /showcase/render/{cache_key}/preview serves PNG. In-memory LRU only (single worker).
SHOWCASE_COMPOSITOR_ENABLED=1
SHOWCASE_COMPOSITOR_CACHE_MAX_ENTRIES=64
SHOWCASE_COMPOSITOR_CANVAS_W=1200
SHOWCASE_COMPOSITOR_CANVAS_H=900
# Phase 1 Studio: physical scale defaults (cm) when client omits wall_width_cm / height
SHOWCASE_STUDIO_WALL_WIDTH_CM=400
SHOWCASE_STUDIO_WALL_HEIGHT_CM=280
# Optional POST /showcase/render field wall_span_cm: real cm width of the focal wall ROI (pairs with physical_width_cm; see docs/SHOWCASE_MOCKUP_ROADMAP.md).
# Optional: background removal via rembg — install: pip install -e ".[showcase]" (pulls rembg[cpu] + onnxruntime), then:
# SHOWCASE_CUTOUT_ENABLED=1
# Scene library JSON (default: packaged app/showcase/data/scene_library_manifest.json). Override path or inline JSON:
SHOWCASE_SCENE_MANIFEST_PATH=/path/to/manifest.json
SHOWCASE_SCENE_MANIFEST_JSON={"pipeline_version":"x","scenes":[]}
# Optional: OpenAI refinement for POST /showcase/options (requires OPENAI_API_KEY).
SHOWCASE_PRESENTATION_LLM_ENABLED=0
SHOWCASE_PRESENTATION_MODEL=gpt-4.1-mini

# V3 agentic pipeline
V3_ASK_ENABLED=1
# Validate generated SQL column names against schema_registry (1=on)
V3_SCHEMA_COLUMN_CHECK=1
# Retry LLM SQL repair after MySQL unknown column (1054), up to N extra attempts
V3_MAX_DB_RETRIES=1
V3_VALIDATOR_MAX_RETRIES=1
V3_CHART_AGENT_ENABLED=0
V3_INSIGHT_LLM_ENABLED=1
V3_MIN_CONFIDENCE=0.55
V3_BLOCK_LOW_CONFIDENCE=0
V3_MEMORY_PGVECTOR_ENABLED=0
V3_MEMORY_USE_MYSQL=1
V3_MEMORY_TABLE_NAME=ai_v3_memory_events
V3_MEMORY_LOG_PATH=

# ERP module AI Insights: scope classifier (requires OPENAI_API_KEY when LLM enabled)
V3_MODULE_SCOPE_LLM_ENABLED=1
V3_MODULE_SCOPE_MODEL=gpt-4.1-mini

# Auth audit (POST /auth/login, /auth/logout). Requires INSERT on ai_v3_copilot_auth_audit (or override table name).
COPILOT_AUTH_AUDIT_ENABLED=1
COPILOT_AUTH_AUDIT_USE_MYSQL=1
COPILOT_AUTH_AUDIT_TABLE=ai_v3_copilot_auth_audit

