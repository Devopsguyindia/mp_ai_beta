COPILOT_ENV=dev

# MySQL (read-only user strongly recommended)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=masterpiece
MYSQL_USERNAME=readonly_user
MYSQL_PASSWORD=change_me

# Query limits
MYSQL_QUERY_TIMEOUT_MS=8000
MYSQL_MAX_ROWS=200

# LLM (optional for now; can run in stub mode without calling an LLM)
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL_SQL=gpt-4.1
OPENAI_MODEL_ROUTER=gpt-4.1-mini
AI_FIRST_SQL_ENABLED=1

# CORS
CORS_ALLOW_ORIGINS=http://localhost:4200,http://127.0.0.1:4200

