{
  "version": "1",
  "critical_note": "ALWAYS add idcompany filter for all queries so the gallery sees only its own data.",
  "global_critical_notes": [
    "When answering queries related to edition types (open, limited, unique, nonstock), always use EditionName column of company_item_data view. Do not return edition_type (0/1/2/3) to the end user.",
    "For artist names: use company_item_data's ArtistFirst and ArtistLast columns (append/concatenate them).",
    "For vendor names: use company_item_data's VendorFirst and VendorLast columns (append/concatenate them).",
    "company_sale has idcompany_customer, NOT idcompany_contact. For top customers by purchases/revenue, prefer company_sale_data with GROUP BY CustomerName or idcompany_customer.",
    "Never expose any id of any table. Never return IDs in any query to show to the user.",
    "For artist, customer, or vendor name columns: replace null/blank/whitespace with 'Anonymous' using COALESCE(NULLIF(TRIM(name_col), ''), 'Anonymous'). Example: SELECT COALESCE(NULLIF(TRIM(CustomerName), ''), 'Anonymous') AS CustomerName, COUNT(*) AS cnt FROM company_sale_data WHERE idcompany = %(idcompany)s GROUP BY COALESCE(NULLIF(TRIM(CustomerName), ''), 'Anonymous') ORDER BY cnt DESC. Apply same pattern for ArtistName, VendorName, CustomerName.",
    "Do NOT invent column names. Use ONLY columns listed in the schema. SaleValue does not exist. For sale value or total sales use SUM(LineTotal) or SUM(total) from company_sale_data.",
    "Always use MM/DD/YYYY format for all dates returned to the user in every query. Format date/datetime columns in the SELECT list (e.g. MySQL: DATE_FORMAT(date_col, '%m/%d/%Y') AS alias) so displayed values are never raw ISO or ambiguous.",
    "Always trim timestamps from dates shown to the user: never return time-of-day with dates. Use DATE() on datetime columns before formatting, or DATE_FORMAT on the date-only portion so output is strictly calendar date in MM/DD/YYYY."
  ],
  "metric_definitions": {
    "Revenue": {
      "label": "Revenue (gross)",
      "formula": "SUM(company_sale.total)",
      "tables": ["company_sale"],
      "filters": "is_sale=1 AND COALESCE(isreturned,0)=0",
      "tax": "inclusive",
      "description": "Gross sale amount including tax. Use company_sale.total. Exclude returned sales."
    },
    "TotalSales": {
      "label": "Total Sales (net)",
      "formula": "SUM(company_sale_data.LineTotal)",
      "tables": ["company_sale_data"],
      "filters": "is_sale=1 AND COALESCE(SaleReturned,0)=0",
      "tax": "exclusive",
      "description": "Net sale amount before tax. Use company_sale_data.LineTotal. Prefer for line-level analytics. Exclude returned lines."
    },
    "Margin": {
      "label": "Margin (line-level)",
      "formula": "CASE WHEN LineTotal > 0 THEN ROUND((LineTotal - IFNULL(ItemCost,0)) / LineTotal * 100, 2) ELSE NULL END",
      "tables": ["company_sale_data"],
      "columns_used": ["LineTotal", "ItemCost"],
      "description": "Profit margin as percent. (LineTotal - ItemCost) / LineTotal * 100. Use ItemCost from company_sale_data."
    },
    "Markup": {
      "label": "Markup (line-level)",
      "formula": "CASE WHEN ItemCost > 0 THEN ROUND((LineTotal - ItemCost) / ItemCost * 100, 2) ELSE NULL END",
      "tables": ["company_sale_data"],
      "columns_used": ["LineTotal", "ItemCost"],
      "description": "Profit markup as percent. (LineTotal - ItemCost) / ItemCost * 100."
    },
    "Returns": {
      "return_sale_flag": "company_sale.isreturned=1 OR company_sale_data.SaleReturned=1",
      "return_line_flag": "company_sale_data.is_returned=1",
      "exclusion_rule": "When computing Revenue or TotalSales, exclude: COALESCE(isreturned,0)=0 or COALESCE(SaleReturned,0)=0",
      "return_amount": "SUM(LineTotal) WHERE is_returned=1, or sales where isreturned=1 (total may be negative)",
      "description": "Returned sales excluded from revenue. Use isreturned, SaleReturned, is_returned for return-specific queries."
    }
  },
